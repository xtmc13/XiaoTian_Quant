# ═══════════════════════════════════════════════════════════════════
# XiaoTianQuant Environment Configuration Template
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Security ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Server ────────────────────────────────────────────────────────
BACKEND_PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── Database ──────────────────────────────────────────────────────
DB_TYPE=sqlite
DATABASE_URL=sqlite:///data/xtquant.db
# PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/xtquant

# ── Redis (optional, for caching) ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379

# ── Proxy (VPN — needed for Binance API from China) ───────────────
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# ── Exchange API Keys ─────────────────────────────────────────────
# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=false

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# ── AI / LLM Providers ────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=

ANTHROPIC_API_KEY=

# ── Notifications ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=XiaoTianQuant <noreply@xtquant.com>

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── ML Server ─────────────────────────────────────────────────────
ML_SERVER_URL=http://localhost:8001

# ── Paper Trading ─────────────────────────────────────────────────
PAPER_TRADING_ENABLED=false
PAPER_TRADING_INITIAL_BALANCE=100000
PAPER_TRADING_FEE_RATE=0.001
PAPER_TRADING_SLIPPAGE=0.0005

# ── Risk Management ───────────────────────────────────────────────
MAX_POSITION_PCT=0.3
MAX_LEVERAGE=5
MAX_DAILY_LOSS_PCT=5.0
MAX_CONSECUTIVE_LOSSES=5
CIRCUIT_BREAKER_ENABLED=true
