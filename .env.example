# XiaoTianQuant Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Security ====================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ==================== Database ====================
DB_TYPE=sqlite  # sqlite or postgresql
DATABASE_URL=sqlite:///data/xtquant.db
# For PostgreSQL: DATABASE_URL=postgresql://xtquant:xtquant123@localhost:5432/xtquant

# PostgreSQL settings (only used with DB_TYPE=postgresql)
POSTGRES_DB=xtquant
POSTGRES_USER=xtquant
POSTGRES_PASSWORD=xtquant123
PG_MAX_CONNECTIONS=150
PG_SHARED_BUFFERS=256MB

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_ENABLED=false

# ==================== Server ====================
BACKEND_PORT=8080
LOG_LEVEL=INFO

# ==================== Exchange API Keys ====================
# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=false

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# Bitget
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# KuCoin
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ==================== AI / LLM ====================
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# ==================== Notifications ====================
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=XiaoTianQuant <noreply@xtquant.com>

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==================== ML Server ====================
ML_SERVER_URL=http://localhost:8001

# ==================== Paper Trading ====================
PAPER_TRADING_ENABLED=false
PAPER_TRADING_INITIAL_BALANCE=100000
PAPER_TRADING_FEE_RATE=0.001
PAPER_TRADING_SLIPPAGE=0.0005

# ==================== Risk Management ====================
MAX_POSITION_PCT=0.3
MAX_LEVERAGE=5
MAX_DAILY_LOSS_PCT=5.0
MAX_CONSECUTIVE_LOSSES=5
CIRCUIT_BREAKER_ENABLED=true
